@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <h2 class="mb-3">Iniciar Sesión</h2>
            <form method="post">
                <div class="mb-3">
                    <label>Correo</label>
                    <input name="correo" class="form-control" />
                </div>
                <div class="mb-3">
                    <label>Clave</label>
                    <input name="clave" type="password" class="form-control" />
                </div>
                <button class="btn btn-primary">Ingresar</button>
                @if (ViewBag.Error != null)
                {
                    <div class="text-danger mt-2">@ViewBag.Error</div>
                }
            </form>
            <div class="mt-2">
                <small class="text-muted">Ingresa tu correo y contraseña registrados.</small>
            </div>
        </div>
    </div>
</div>
