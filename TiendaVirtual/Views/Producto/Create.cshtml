@model TiendaVirtual.Models.Producto

@{
    ViewData["Title"] = "Crear Producto";
}

<div class="container mt-4">
    <h2>Crear Producto</h2>

    <form asp-action="Create">
        <div class="mb-3">
            <label asp-for="Nombre" class="form-label"></label>
            <input asp-for="Nombre" class="form-control" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Precio" class="form-label"></label>
            <input asp-for="Precio" class="form-control" />
            <span asp-validation-for="Precio" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Stock" class="form-label"></label>
            <input asp-for="Stock" class="form-control" />
            <span asp-validation-for="Stock" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="CategoriaId" class="form-label">Categoría</label>
            <select asp-for="CategoriaId" class="form-select"
                    asp-items="ViewBag.CategoriaId">
                <option value="">-- Seleccione una categoría --</option>
            </select>
            <span asp-validation-for="CategoriaId" class="text-danger"></span>
        </div>

        <a href="/Producto/Index" class="btn btn-secondary">Volver</a>
        <button type="submit" class="btn btn-primary">Guardar</button>
    </form>
</div>